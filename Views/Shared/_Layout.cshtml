    <canvas id="matrix-left"  class="matrix-canvas matrix-canvas-left"></canvas>
    <canvas id="matrix-right" class="matrix-canvas matrix-canvas-right"></canvas>

    <div class="nb-page-container">
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
