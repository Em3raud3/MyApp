    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        /* ── Matrix digital rain ── */
        (function () {
            var CHARS = 'ｦｧｨｩｪｫｬｭｮｯｰｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇﾈﾉﾊﾋﾌﾍﾎﾏﾐﾑﾒﾓﾔﾕﾖﾗﾘﾙﾚﾛﾜﾝ0123456789ABCDEF@@#$%&';
            var FONT_SIZE = 14;
            var COLORS = ['#a855f7', '#c084fc', '#7c3aed', '#00eefc', '#6d28d9'];
            var HEAD_COLOR = '#e9d5ff';

            function initCanvas(canvas) {
                var ctx = canvas.getContext('2d');
                var W, H, cols, drops, dropColors, speeds, glitchTimers;

                function resize() {
                    W = canvas.width  = canvas.offsetWidth;
                    H = canvas.height = window.innerHeight;
                    cols = Math.floor(W / FONT_SIZE);
                    drops = [];
                    dropColors = [];
                    speeds = [];
                    glitchTimers = [];
                    for (var i = 0; i < cols; i++) {
                        drops[i]        = Math.random() * -(H / FONT_SIZE);
                        dropColors[i]   = COLORS[Math.floor(Math.random() * COLORS.length)];
                        speeds[i]       = 0.3 + Math.random() * 0.7;
                        glitchTimers[i] = Math.floor(Math.random() * 120);
                    }
                }

                window.addEventListener('resize', resize);
                resize();

                function draw() {
                    ctx.fillStyle = 'rgba(0, 0, 0, 0.045)';
                    ctx.fillRect(0, 0, W, H);
                    ctx.font = FONT_SIZE + 'px monospace';

                    for (var i = 0; i < cols; i++) {
                        glitchTimers[i]--;
                        if (glitchTimers[i] <= 0) {
                            dropColors[i]   = COLORS[Math.floor(Math.random() * COLORS.length)];
                            glitchTimers[i] = 60 + Math.floor(Math.random() * 180);
                        }

                        var y  = Math.floor(drops[i]) * FONT_SIZE;
                        var x  = i * FONT_SIZE;
                        var ch = CHARS[Math.floor(Math.random() * CHARS.length)];

                        ctx.fillStyle  = HEAD_COLOR;
                        ctx.shadowColor = HEAD_COLOR;
                        ctx.shadowBlur  = 8;
                        ctx.fillText(ch, x, y);

                        if (y - FONT_SIZE >= 0) {
                            ctx.fillStyle  = dropColors[i];
                            ctx.shadowColor = dropColors[i];
                            ctx.shadowBlur  = 6;
                            ctx.fillText(CHARS[Math.floor(Math.random() * CHARS.length)], x, y - FONT_SIZE);
                        }

                        ctx.shadowBlur = 0;
                        drops[i] += speeds[i];

                        if (drops[i] * FONT_SIZE > H && Math.random() > 0.975) {
                            drops[i]  = Math.random() * -(H / FONT_SIZE) * 0.5;
                            speeds[i] = 0.3 + Math.random() * 0.7;
                        }
                    }

                    requestAnimationFrame(draw);
                }

                draw();
            }

            initCanvas(document.getElementById('matrix-left'));
            initCanvas(document.getElementById('matrix-right'));
        })();

        /* ── Synced breathe driver ── */
        (function () {
            var DURATION = 6000; /* ms — must match what was the CSS duration */
            var root = document.documentElement.style;

            function easeInOut(t) {
                return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            }

            function tick(now) {
                var t = (now % DURATION) / DURATION;          /* 0 → 1 linear */
                /* bounce: 0→1→0 over one cycle */
                var wave = t < 0.5 ? easeInOut(t * 2) : easeInOut((1 - t) * 2);
                var dim  = 1 - wave;                           /* 1 = peak dim */

                /* brackets */
                var opacity = 1 - dim * 0.55;                 /* 1 → 0.45 */
                var glow0   = (1  - dim * 0.8).toFixed(3);    /* 1    → 0.2  */
                var glow1   = (0.7 - dim * 0.65).toFixed(3);  /* 0.7  → 0.05 */
                var glow2   = (0.35 - dim * 0.32).toFixed(3); /* 0.35 → 0.03 */
                var dimGlow0 = (0.3 - dim * -0.7 * 0).toFixed(3);
                var glowStr = dim > 0.5
                    ? 'drop-shadow(0 0 2px rgba(252,249,1,' + (0.3 * (1 - (dim - 0.5) * 2)).toFixed(3) + ')) drop-shadow(0 0 6px rgba(252,249,1,' + (0.1 * (1 - (dim - 0.5) * 2)).toFixed(3) + '))'
                    : 'drop-shadow(0 0 10px rgba(252,249,1,' + glow0 + ')) drop-shadow(0 0 22px rgba(252,249,1,' + glow1 + ')) drop-shadow(0 0 40px rgba(252,249,1,' + glow2 + '))';

                root.setProperty('--breathe-opacity', opacity.toFixed(3));
                root.setProperty('--breathe-glow', glowStr);

                /* ticks */
                root.setProperty('--long-tick-alpha',  (0.55 - dim * 0.5).toFixed(3));
                root.setProperty('--short-tick-alpha', (0.35 - dim * 0.3).toFixed(3));

                requestAnimationFrame(tick);
            }

            requestAnimationFrame(tick);
        })();
    </script>
</body>
</html>
