<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyApp.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand {
            transition: transform 0.2s ease, opacity 0.2s ease;
        }

            .navbar-brand:hover {
                transform: scale(1.08);
                opacity: 0.85;
            }

        .navbar-nav .nav-link {
            position: relative;
            transition: opacity 0.2s ease;
            padding-bottom: 0.4rem;
        }

            .navbar-nav .nav-link::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 0;
                height: 2px;
                background-color: #fff;
                transition: width 0.3s ease;
            }

            .navbar-nav .nav-link:hover {
                opacity: 0.8;
            }

                .navbar-nav .nav-link:hover::after {
                    width: 100%;
                }

        /* Suppress Bootstrap's built-in caret — we use .nav-caret instead */
        .navbar-nav .dropdown-toggle::after {
            display: none;
        }

        /* Chevron icon next to dropdown labels */
        .nav-caret {
            display: inline-block;
            margin-left: 0.3rem;
            font-size: 1.1rem;
            vertical-align: middle;
            transition: transform 0.2s ease;
            opacity: 0.85;
        }

        .navbar-nav .dropdown:hover .nav-caret {
            transform: rotate(180deg);
        }

        /* Open dropdown on hover */
        .navbar-nav .dropdown:hover > .dropdown-menu {
            display: block;
            margin-top: 0;
        }

        /* Dropdown menu styling */
        .dropdown-menu {
            background-color: #166a39;
            border: 1px solid #125c31;
            border-radius: 0.375rem;
            padding: 0.25rem 0;
            min-width: 13rem;
        }

        .dropdown-item {
            color: #fff;
            font-size: 0.9rem;
            padding: 0.5rem 1.1rem;
            transition: background-color 0.15s ease;
        }

            .dropdown-item:hover,
            .dropdown-item:focus {
                background-color: #125c31;
                color: #fff;
            }

        .nav-link.dropdown-toggle {
            padding-right: 1.25rem;
        }

        /* Vertical divider */
        .nav-divider {
            width: 2px;
            height: 1.4rem;
            background-color: rgba(255, 255, 255, 0.4);
            border-radius: 1px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: #1E8449;">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MyApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Pages <span class="nav-caret">▾</span>
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="BasicPage">Basic Page</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="BasicPageAlt">Basic Page Alt</a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item px-2 d-flex align-items-center"><span class="nav-divider"></span></li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Tables <span class="nav-caret">▾</span>
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Table">Table</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="TableNoHighlight">Table No Highlight</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="TableAccordion">Table Accordion</a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item px-2 d-flex align-items-center"><span class="nav-divider"></span></li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="WIP">WIP</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-white" style="background-color: #1E8449;">
        <div class="container">
            &copy; 2026 - MyApp
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>