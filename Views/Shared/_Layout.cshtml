<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyApp.styles.css" asp-append-version="true" />
    <style>
        /* ── Navbar ── */
        .nb-navbar {
            background-color: #0a0a0a;
            border-bottom: 2px solid var(--nb-primary);
            padding: 0;
            position: relative;
            box-shadow: 0 2px 0 rgba(252, 249, 1, 0.08),
                        0 4px 24px rgba(0, 0, 0, 0.7);
        }

        /* scanline overlay on the bar itself */
        .nb-navbar::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 3px,
                rgba(0, 0, 0, 0.18) 3px,
                rgba(0, 0, 0, 0.18) 4px
            );
            pointer-events: none;
            z-index: 0;
        }

        /* bottom accent line flicker */
        .nb-navbar::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(
                90deg,
                transparent 0%,
                var(--nb-primary) 20%,
                #fff 50%,
                var(--nb-primary) 80%,
                transparent 100%
            );
            opacity: var(--breathe-opacity, 1);
            pointer-events: none;
        }

        .nb-navbar .container-fluid {
            position: relative;
            z-index: 1;
            padding-top: 0.55rem;
            padding-bottom: 0.55rem;
        }

        .nb-navbar .navbar-brand {
            font-family: var(--nb-font-display);
            font-weight: 900;
            font-size: 1.2em;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--nb-primary);
            transition: color 0.15s ease, text-shadow 0.15s ease;
            text-shadow: 0 0 8px rgba(252, 249, 1, 0.6),
                         0 0 20px rgba(252, 249, 1, 0.25);
            position: relative;
        }

        /* corner tick on brand */
        .nb-navbar .navbar-brand::before {
            content: '//';
            font-size: 0.65em;
            font-weight: 400;
            letter-spacing: 0;
            color: var(--nb-secondary);
            margin-right: 0.35rem;
            opacity: 0.75;
        }

        .nb-navbar .navbar-brand:hover {
            color: #fff;
            text-shadow: 0 0 12px rgba(255, 255, 255, 0.9),
                         0 0 30px rgba(252, 249, 1, 0.5);
        }

        .nb-navbar .nav-link {
            font-family: var(--nb-font-display);
            font-weight: 600;
            font-size: 0.75em;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--nb-on-surface-muted) !important;
            position: relative;
            padding: 0.55rem 0.6rem;
            transition: color 0.15s ease;
        }

        .nb-navbar .nav-link::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: var(--nb-primary);
            transform: scaleX(0);
            transition: transform 0.2s ease;
            transform-origin: left;
        }

        .nb-navbar .nav-link::after { display: none; }

        .nb-navbar .nav-link:hover {
            color: var(--nb-primary) !important;
        }

        .nb-navbar .nav-link:hover::before {
            transform: scaleX(1);
        }

        /* Suppress Bootstrap caret */
        .nb-navbar .dropdown-toggle::after { display: none; }

        .nav-caret {
            display: inline-block;
            margin-left: 0.2rem;
            font-size: 0.75em;
            vertical-align: middle;
            transition: transform 0.2s ease;
            color: var(--nb-primary);
            opacity: 0.6;
        }

        .nb-navbar .dropdown:hover .nav-caret {
            transform: rotate(180deg);
            opacity: 1;
        }

        .nb-navbar .dropdown-toggle {
            color: var(--nb-on-surface-muted) !important;
        }

        .nb-navbar .dropdown-toggle:hover {
            color: var(--nb-primary) !important;
        }

        /* Hover-open dropdown */
        .nb-navbar .dropdown:hover > .dropdown-menu {
            display: block;
            margin-top: 0;
        }

        /* Dropdown menu */
        .dropdown-menu {
            background-color: #0d0d0d;
            border: 1px solid rgba(252, 249, 1, 0.25);
            border-top: 2px solid var(--nb-primary);
            border-radius: 0;
            padding: 0.3rem 0;
            min-width: 15rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.8),
                        0 0 0 1px rgba(252, 249, 1, 0.04) inset;
        }

        /* dropdown scanlines */
        .dropdown-menu::before {
            content: '';
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 3px,
                rgba(0, 0, 0, 0.12) 3px,
                rgba(0, 0, 0, 0.12) 4px
            );
            pointer-events: none;
            z-index: 0;
        }

        .dropdown-item {
            font-family: var(--nb-font-display);
            font-size: 0.75em;
            font-weight: 600;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            color: var(--nb-on-surface-muted);
            padding: 0.5rem 1.1rem;
            transition: background-color 0.12s ease, color 0.12s ease,
                        padding-left 0.12s ease;
            position: relative;
            z-index: 1;
        }

        .dropdown-item::before {
            content: '›';
            position: absolute;
            left: 0.5rem;
            opacity: 0;
            color: var(--nb-primary);
            transition: opacity 0.12s ease;
        }

        .dropdown-item:hover,
        .dropdown-item:focus {
            background-color: rgba(252, 249, 1, 0.05);
            color: var(--nb-primary);
            padding-left: 1.5rem;
        }

        .dropdown-item:hover::before,
        .dropdown-item:focus::before {
            opacity: 1;
        }

        /* Vertical divider */
        .nav-divider {
            width: 1px;
            height: 1rem;
            background: linear-gradient(to bottom,
                transparent,
                rgba(252, 249, 1, 0.4),
                transparent);
        }

        .dropdown-menu-end {
            right: 0;
            left: auto;
        }

        /* ── Food dropdown (purple) ── */
        .nav-food > .nav-link {
            color: #a855f7 !important;
        }

        .nav-food > .nav-link:hover {
            color: #c084fc !important;
        }

        .nav-food > .nav-link::before {
            background-color: #a855f7;
        }

        .nav-food .nav-caret {
            color: #a855f7;
        }

        .nav-food .dropdown-menu {
            border-top-color: #a855f7;
        }

        .nav-food .dropdown-item:hover,
        .nav-food .dropdown-item:focus {
            background-color: rgba(168, 85, 247, 0.08);
            color: #c084fc;
        }

        .nav-food .dropdown-item::before {
            color: #a855f7;
        }

        /* ── Nav status dot ── */
        .nb-status-dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #00ff88;
            margin-right: 0.5rem;
            box-shadow: 0 0 6px #00ff88;
            opacity: var(--breathe-opacity, 1);
            vertical-align: middle;
        }

        .nb-brand-tag {
            font-size: 0.5em;
            font-weight: 400;
            letter-spacing: 0.15em;
            color: var(--nb-secondary);
            opacity: 0.6;
            margin-left: 0.4rem;
            vertical-align: middle;
            font-family: var(--nb-font-display);
        }

        /* ── Matrix rain canvases ── */
        .matrix-canvas {
            position: fixed;
            top: 0;
            width: 240px;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
            opacity: 0.55;
        }

        .matrix-canvas-left  { left: 0; }
        .matrix-canvas-right { right: 0; }

        /* ── Page container ── */
        .nb-page-container {
            background-color: var(--nb-bg);
            min-height: calc(100vh - 60px);
        }

        /* ── Sticky header ── */
        header {
            position: sticky;
            top: 0;
            z-index: 10000;
        }
    </style>
</head>
<body>
