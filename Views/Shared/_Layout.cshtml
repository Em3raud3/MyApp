<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyApp</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyApp.styles.css" asp-append-version="true" />
    <style>
        /* ── Navbar ── */
        .nb-navbar {
            background-color: var(--nb-surface-low);
            border-bottom: 2px solid var(--nb-primary);
            padding: 0.6rem 0;
        }

        .nb-navbar .navbar-brand {
            font-family: var(--nb-font-display);
            font-weight: 800;
            font-size: 1.15em;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--nb-primary);
            transition: color 0.2s ease;
        }

        .nb-navbar .navbar-brand:hover {
            color: #fff;
        }

        .nb-navbar .nav-link {
            font-family: var(--nb-font-display);
            font-weight: 600;
            font-size: 0.8em;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--nb-on-surface) !important;
            position: relative;
            padding-bottom: 0.4rem;
            transition: color 0.2s ease;
        }

        .nb-navbar .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--nb-primary);
            transition: width 0.25s ease;
        }

        .nb-navbar .nav-link:hover {
            color: var(--nb-primary) !important;
        }

        .nb-navbar .nav-link:hover::after {
            width: 100%;
        }

        /* Suppress Bootstrap caret */
        .nb-navbar .dropdown-toggle::after { display: none; }

        .nav-caret {
            display: inline-block;
            margin-left: 0.25rem;
            font-size: 0.9em;
            vertical-align: middle;
            transition: transform 0.2s ease;
            color: var(--nb-secondary);
        }

        .nb-navbar .dropdown:hover .nav-caret {
            transform: rotate(180deg);
        }

        /* Hover-open dropdown */
        .nb-navbar .dropdown:hover > .dropdown-menu {
            display: block;
            margin-top: 0;
        }

        .nb-navbar .dropdown-toggle {
            color: var(--nb-secondary) !important;
        }

        .nb-navbar .dropdown-toggle:hover {
            color: var(--nb-primary) !important;
        }

        /* Dropdown menu */
        .dropdown-menu {
            background-color: var(--nb-surface-low);
            border: 1px solid var(--nb-outline);
            border-top: 2px solid var(--nb-primary);
            border-radius: 0;
            padding: 0.25rem 0;
            min-width: 14rem;
        }

        .dropdown-item {
            font-family: var(--nb-font-display);
            font-size: 0.78em;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--nb-on-surface-muted);
            padding: 0.5rem 1.1rem;
            transition: background-color 0.15s ease, color 0.15s ease;
        }

        .dropdown-item:hover,
        .dropdown-item:focus {
            background-color: rgba(252, 249, 1, 0.07);
            color: var(--nb-primary);
        }

        /* Vertical divider */
        .nav-divider {
            width: 1px;
            height: 1.2rem;
            background-color: var(--nb-outline);
        }

        .dropdown-menu-end {
            right: 0;
            left: auto;
        }

        /* ── Page container ── */
        .nb-page-container {
            background-color: var(--nb-bg);
            min-height: calc(100vh - 60px);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm nb-navbar mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MyApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Pages <span class="nav-caret">▾</span>
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="BasicFormat">Basic Format</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="BasicPage">Basic Page</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="BasicPageSimple">Basic Page Simple</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="BasicPageAlt">Basic Page Alt</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="BasicPageList">Basic Page List</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="BasicPagePretty">Basic Page Pretty</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="RegionPage">Region Page</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="WVLawPage">West Virginia Law Page</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="NewsPage">News Page</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="LicensePage">License Page</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="LicenseGallery">License Gallery</a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item px-2 d-flex align-items-center"><span class="nav-divider"></span></li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Tables <span class="nav-caret">▾</span>
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="Table">Table</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="TableNoHighlight">Table No Highlight</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="TableAccordion">Table Accordion</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="TableFilters">Table Filters</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Website" asp-action="QuickNavigation">Quick Navigation</a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item px-2 d-flex align-items-center"><span class="nav-divider"></span></li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                ADA <span class="nav-caret">▾</span>
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Ada" asp-action="ADA_Compliance">WCAG 2.0</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-controller="Ada" asp-action="PDF_Remediation">PDF &amp; Document Remediation</a>
                                </li>
                            </ul>
                        </li>

                         <li class="nav-item ms-sm-auto">
                            <a class="nav-link" style="color: #E50914 !important;" asp-area="" asp-controller="Home" asp-action="WIP">WIP</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="nb-page-container">
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
