<style>
    /* ── Page wrapper ── */
    .wip-wrapper {
        padding-left: 15rem;
        padding-right: 15rem;
    }

    @@media (max-width: 1200px) {
        .wip-wrapper {
            padding-left: 6rem;
            padding-right: 6rem;
        }
    }

    @@media (max-width: 768px) {
        .wip-wrapper {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }

    /* ── Page meta ── */
    .wip-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .wip-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: #2d3748;
        color: #fff;
        font-size: 1.01rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.3rem 0.75rem;
        border-radius: 0.25rem;
    }

        .wip-badge svg {
            color: #EAAA00;
        }

    /* ── Grid ── */
    .wip-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 768px) {
        .wip-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .wip-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── Plate card ── */
    .wip-card {
        border: 1px solid #cfd8e3;
        border-radius: 0.375rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background-color: #fff;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

        .wip-card:hover {
            box-shadow: 0 4px 16px rgba(45, 55, 72, 0.13);
            transform: translateY(-2px);
        }

    /* ── Inner link wraps image + title ── */
    .wip-card-link {
        display: flex;
        flex-direction: column;
        flex: 1;
        text-decoration: none;
        color: inherit;
    }

        .wip-card-link:hover {
            text-decoration: none;
        }

            .wip-card-link:hover .wip-card-title {
                color: #1a4a80;
                text-decoration: underline;
            }

    .wip-card-img {
        background-color: #f4f6fb;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        border-bottom: 1px solid #cfd8e3;
        min-height: 100px;
    }

    .wip-card-title {
        padding: 0.65rem 0.85rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: #2b6cb0;
        line-height: 1.4;
        flex-grow: 1;
        text-align: center;
    }

    /* ── No-link variant ── */
    .wip-card-nolink .wip-card-title {
        color: #4a5568;
    }

    .wip-card-nolink:hover {
        box-shadow: none;
        transform: none;
    }
