<style>
    /* ── Page wrapper ── */
    .pr-wrapper {
        padding-left: 15rem;
        padding-right: 15rem;
    }

    @@media (max-width: 1200px) {
        .pr-wrapper {
            padding-left: 6rem;
            padding-right: 6rem;
        }
    }

    @@media (max-width: 768px) {
        .pr-wrapper {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }

    /* ── Page meta ── */
    .pr-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
    }

    .pr-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: #2d3748;
        color: #fff;
        font-size: 1.01rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.3rem 0.75rem;
        border-radius: 0.25rem;
    }

        .pr-badge svg {
            color: #EAAA00;
        }

    /* ── Lead ── */
    .pr-lead {
        font-size: 1.43rem;
        color: #4a5568;
        line-height: 1.8;
        border-left: 4px solid #EAAA00;
        padding: 0.85rem 1.25rem;
        background-color: #fffdf0;
        border-radius: 0 0.375rem 0.375rem 0;
        margin-bottom: 1.25rem;
    }

        .pr-lead strong {
            color: #2d3748;
        }

    /* ── Shared card ── */
    .pr-card {
        border: 1px solid #cfd8e3;
        border-radius: 0.375rem;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .pr-card-header {
        background-color: #2d3748;
        color: #fff;
        padding: 0.75rem 1.25rem;
        font-weight: 600;
        font-size: 1.43rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

        .pr-card-header svg {
            color: #EAAA00;
            flex-shrink: 0;
        }

    .pr-card-body {
        padding: 1.25rem;
        background-color: #fff;
        color: #4a5568;
        font-size: 1.37rem;
        line-height: 1.75;
    }

        .pr-card-body a {
            color: #2b6cb0;
            font-weight: 500;
        }

            .pr-card-body a:hover {
                color: #1a4a80;
            }

        .pr-card-body strong {
            color: #2d3748;
        }

    /* ── FAQ items ── */
    .faq-item {
        padding: 1.1rem 0;
        border-bottom: 1px solid #edf1f7;
    }

        .faq-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .faq-item:first-child {
            padding-top: 0;
        }

    .faq-q {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        font-weight: 700;
        color: #2d3748;
        font-size: 1.37rem;
        margin-bottom: 0.6rem;
        line-height: 1.5;
    }

        .faq-q::before {
            content: "Q";
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 1.9rem;
            height: 1.9rem;
            background-color: #EAAA00;
            color: #fff;
            font-size: 1rem;
            font-weight: 800;
            border-radius: 0.25rem;
            flex-shrink: 0;
            margin-top: 0.1rem;
        }

    .faq-a {
        padding-left: 2.65rem;
        color: #4a5568;
        font-size: 1.3rem;
        line-height: 1.75;
    }

        .faq-a a {
            color: #2b6cb0;
            font-weight: 500;
        }

            .faq-a a:hover {
                color: #1a4a80;
            }

    /* ── Credit note ── */
    .pr-credit {
        margin-top: 0.85rem;
        padding: 0.6rem 0.9rem;
        background-color: #f8f9fc;
        border-left: 3px solid #5a6e82;
        border-radius: 0 0.25rem 0.25rem 0;
        font-size: 1.21rem;
        color: #5a6e82;
    }

        .pr-credit a {
            color: #2b6cb0;
            font-weight: 500;
        }

    /* ── Contact bar ── */
    .pr-contact {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.85rem;
        padding: 1rem 1.25rem;
        background-color: #f4f6fb;
        border: 1px solid #cfd8e3;
        border-left: 4px solid #EAAA00;
        border-radius: 0 0.375rem 0.375rem 0;
        max-width: 33%;
        margin: 0 auto;
    }

        .pr-contact svg {
            color: #EAAA00;
            flex-shrink: 0;
        }

        .pr-contact strong {
            display: block;
            font-size: 0.98rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #5a6e82;
            margin-bottom: 0.15rem;
        }

        .pr-contact a {
            color: #2b6cb0;
            font-weight: 600;
            font-size: 1.3rem;
            text-decoration: none;
        }

            .pr-contact a:hover {
                text-decoration: underline;
            }

    .pr-contact-divider {
        width: 1px;
        height: 2rem;
        background-color: #cfd8e3;
        flex-shrink: 0;
    }

    @@media (max-width: 576px) {
        .pr-contact {
            max-width: 100%;
        }
