@{
    ViewData["Title"] = "PDF & Document Remediation";
}

<style>

    .pr-wrapper {
        padding-left: 4rem;
        padding-right: 4rem;
    }

    @@media (max-width: 1200px) {
        .pr-wrapper {
            padding-left: 6rem;
            padding-right: 6rem;
        }
    }

    @@media (max-width: 768px) {
        .pr-wrapper {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }

    /* ── Page meta ── */
    .pr-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
    }

    .pr-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: var(--nb-surface-high);
        color: var(--nb-on-surface);
        border: 1px solid var(--nb-outline);
        font-size: 0.71em;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.3rem 0.75rem;
    }

        .pr-badge svg {
            color: var(--nb-primary);
        }

    /* ── Page title ── */
    .pr-page-title {
        font-family: var(--nb-font-display);
        font-size: 2em;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--nb-on-surface);
        margin: 0.5rem 0 1rem;
        line-height: 1.2;
    }

        .pr-page-title span {
            color: var(--nb-primary);
        }

    /* ── Lead ── */
    .pr-lead {
        font-size: 0.96em;
        color: #c0c0c0;
        line-height: 1.8;
        border-left: 4px solid var(--nb-primary);
        padding: 0.85rem 1.25rem;
        background-color: #161600;
        margin-bottom: 1.25rem;
    }

        .pr-lead strong {
            color: var(--nb-on-surface);
        }

        .pr-lead p:first-child {
            margin-top: 0;
        }

        .pr-lead p:last-of-type {
            margin-bottom: 0;
        }

    /* ── Shared card ── */
    .pr-card {
        border: 1px solid #484848;
        border-top: 3px solid var(--nb-primary);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .pr-card-header {
        background-color: var(--nb-surface-high);
        color: var(--nb-on-surface);
        padding: 0.75rem 1.25rem;
        font-family: var(--nb-font-display);
        font-weight: 700;
        font-size: 0.875em;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        border-bottom: 2px solid var(--nb-primary);
    }

        .pr-card-header svg {
            color: var(--nb-primary);
            flex-shrink: 0;
        }

    .pr-card-body {
        padding: 1.25rem;
        background-color: #272727;
        color: #c0c0c0;
        font-size: 0.875em;
        line-height: 1.75;
    }

    /* ── Items ── */
    .ada-item {
        padding: 1.1rem 0;
        border-bottom: 1px solid #353535;
    }

        .ada-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .ada-item:first-child {
            padding-top: 0;
        }

    .ada-item-header {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .ada-criterion {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 3rem;
        height: 1.9rem;
        background-color: var(--nb-primary);
        color: var(--nb-on-primary);
        font-family: var(--nb-font-display);
        font-size: 0.65em;
        font-weight: 800;
        flex-shrink: 0;
        padding: 0 0.4rem;
        margin-top: 0.1rem;
        letter-spacing: 0.02em;
    }

    .ada-title {
        font-family: var(--nb-font-display);
        font-weight: 700;
        color: var(--nb-primary);
        font-size: 0.875em;
        line-height: 1.5;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .ada-desc {
        padding-left: 3.75rem;
        color: #c0c0c0;
        font-size: 0.875em;
        line-height: 1.75;
        margin-bottom: 0.5rem;
    }

    .ada-desc-noindent {
        color: #c0c0c0;
        font-size: 0.875em;
        line-height: 1.75;
        margin-bottom: 0.5rem;
    }

    .pr-card-intro {
        margin-bottom: 1rem;
    }

</style>

<div class="pr-wrapper py-4">

    <div class="pr-meta">
        <span class="pr-badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1L14 5.5z"/>
            </svg>
            PDF &amp; Document Remediation
        </span>
    </div>

    <h1 class="pr-page-title"><span style="color: #E50914;">PDF &amp; Document</span> <span>Remediation</span></h1>

    <div class="pr-lead">
        <p>This document was prepared by the West Virginia Office of Technology and is for guidance purposes only. This is not a legal opinion and individual agencies/departments should rely on their own judgement for a final determination.</p>
        <p>To effectively manage our upcoming <strong>WCAG 2.1 AA</strong> compliance efforts, we must establish a clear, common agreement on which legacy PDF documents are exempt from mandatory remediation. The core challenge lies in defining the criteria for the <strong>Archived Web Content Exception</strong>, particularly the phrase "No Current Use."</p>
    </div>

    <div class="pr-card">
        <div class="pr-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 16 16">
                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1L14 5.5z"/>
            </svg>
            Archiving Guidelines
        </div>
        <div class="pr-card-body">

            <div class="ada-item">
                <div class="ada-item-header">
                    <span class="ada-title">Overview</span>
                </div>
                <div class="ada-desc-noindent">WCAG and federal standards allow older, inactive content to remain online as Archived Content without full remediation, provided it is kept solely for record retention, legal, or historical purposes.</div>
            </div>

            <div class="ada-item">
                <div class="ada-item-header">
                    <span class="ada-title">Common Archived Assets</span>
                </div>
                <div class="ada-desc-noindent">Outdated PDFs, historical reports, old meeting minutes, financial statements, legacy webpages, and inactive multimedia (training videos/audio).</div>
            </div>

            <div class="ada-item">
                <div class="ada-item-header">
                    <span class="ada-title">Compliance Requirements</span>
                </div>
                <div class="ada-desc-noindent">For a file to be exempt as "archived," it must meet all four of the following conditions:</div>
                <ul class="ada-desc-noindent mt-1" style="padding-left: 1.25rem;">
                    <li><strong>Inactive</strong> — the content is no longer updated or actively used.</li>
                    <li><strong>Labeled</strong> — it is clearly identified as archived on the page.</li>
                    <li><strong>On-Demand Access</strong> — it remains available for reference when requested.</li>
                    <li><strong>Non-Interference</strong> — it does not block or disrupt access to other content.</li>
                </ul>
            </div>

        </div>
    </div>

    <div class="pr-card">
        <div class="pr-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
            </svg>
            Key Legal Criteria (Per DOJ ADA Title II Guidance)
        </div>
        <div class="pr-card-body">
            <div class="ada-desc-noindent pr-card-intro">
                To be considered exempt, a PDF must meet <strong>all four</strong> of the following criteria as they relate to the compliance deadlines (e.g., April 24, 2026 for larger public entities):
            </div>

            <div class="ada-item">
                <div class="ada-item-header">
                    <span class="ada-criterion">1</span>
                    <span class="ada-title">Created Before Compliance Date</span>
                </div>
                <div class="ada-desc">Document was created, or is a scanned reproduction of an item created, before the mandated compliance deadline.</div>
            </div>

            <div class="ada-item">
                <div class="ada-item-header">
                    <span class="ada-criterion">2</span>
                    <span class="ada-title">Limited Purpose</span>
                </div>
                <div class="ada-desc">Retained exclusively for reference, research, or recordkeeping.</div>
            </div>

            <div class="ada-item">
                <div class="ada-item-header">
                    <span class="ada-criterion">3</span>
                    <span class="ada-title">No Current Use</span>
                </div>
                <div class="ada-desc">NOT currently used to apply for, gain access to, or participate in any current service, program, or activity. The following constitutes <strong>"Current Use"</strong> and would immediately remove a document's exemption status, requiring remediation:</div>
                <div class="ada-desc">
                    <ul style="padding-left: 1.25rem; margin-bottom: 0;">
                        <li><strong>Forms</strong> — Any PDF required to be printed, completed, and submitted for any current enrollment, permit, or service.</li>
                        <li><strong>Instructional Materials</strong> — A PDF that is required reading or a required reference for an active course, training program, or employee on-boarding process.</li>
                        <li><strong>Active Links</strong> — Any PDF that is prominently linked or referenced from a current, high-traffic page — regardless of its age — suggesting it is a current resource.</li>
                        <li><strong>Active Policies</strong> — Any policy, handbook, or organizational chart that is actively in effect or referenced for current operations.</li>
                    </ul>
                </div>
            </div>

            <div class="ada-item">
                <div class="ada-item-header">
                    <span class="ada-criterion">4</span>
                    <span class="ada-title">Not Altered</span>
                </div>
                <div class="ada-desc">Has not been altered or updated since the date of archiving.</div>
            </div>

        </div>
    </div>

</div>
