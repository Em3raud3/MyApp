@model IEnumerable<MyApp.Models.Recipe>
@{
    ViewData["Title"] = "Recipes";
}

<style>
    .food-wrapper {
        padding-left: 4rem;
        padding-right: 4rem;
    }

    @@media (max-width: 1200px) {
        .food-wrapper {
            padding-left: 2rem;
            padding-right: 2rem;
        }
    }

    @@media (max-width: 768px) {
        .food-wrapper {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }

    .food-page-title {
        font-family: var(--nb-font-display);
        font-size: 2em;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--nb-on-surface);
        margin: 0.5rem 0 1.5rem;
        line-height: 1.2;
    }

    .food-page-title span {
        color: #a855f7;
    }

    .recipe-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .recipe-card {
        border: 1px solid #484848;
        border-top: 3px solid #a855f7;
        background-color: #272727;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .recipe-card-body {
        padding: 1.1rem 1.25rem;
        flex: 1;
    }

    .recipe-name {
        font-family: var(--nb-font-display);
        font-weight: 700;
        font-size: 0.95em;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #a855f7;
        margin-bottom: 0.4rem;
    }

    .recipe-desc {
        font-size: 0.825em;
        color: #c0c0c0;
        line-height: 1.65;
        margin-bottom: 0.75rem;
    }

    .recipe-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .recipe-tag {
        font-size: 0.68em;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--nb-on-surface);
        background-color: var(--nb-surface-high);
        border: 1px solid #484848;
        padding: 0.2rem 0.55rem;
    }

    .food-empty {
        color: #c0c0c0;
        font-size: 0.875em;
        padding: 2rem 0;
    }
</style>

<div class="food-wrapper py-4">

    <h1 class="food-page-title">My <span>Recipes</span></h1>

    @if (!Model.Any())
    {
        <p class="food-empty">No recipes yet. Add one to get started!</p>
    }
    else
    {
        <div class="recipe-grid">
            @foreach (var recipe in Model)
            {
                <div class="recipe-card">
                    <div class="recipe-card-body">
                        <div class="recipe-name">@recipe.Name</div>
                        @if (!string.IsNullOrWhiteSpace(recipe.Description))
                        {
                            <div class="recipe-desc">@recipe.Description</div>
                        }
                        @if (recipe.Ingredients.Any())
                        {
                            <div class="recipe-tags">
                                @foreach (var ingredient in recipe.Ingredients)
                                {
                                    <span class="recipe-tag">@ingredient.Name</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>
