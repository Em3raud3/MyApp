@model IEnumerable<MyApp.Models.Ingredient>
@{
    ViewData["Title"] = "Shopping List";
    var grouped = Model.GroupBy(i => i.Category ?? "Uncategorized").OrderBy(g => g.Key);
}

<style>
    .food-wrapper {
        padding-left: 4rem;
        padding-right: 4rem;
    }

    @@media (max-width: 1200px) {
        .food-wrapper {
            padding-left: 2rem;
            padding-right: 2rem;
        }
    }

    @@media (max-width: 768px) {
        .food-wrapper {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }

    .food-page-title {
        font-family: var(--nb-font-display);
        font-size: 2em;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--nb-on-surface);
        margin: 0.5rem 0 1.5rem;
        line-height: 1.2;
    }

    .food-page-title span {
        color: #a855f7;
    }

    .sl-category {
        margin-bottom: 1.5rem;
    }

    .sl-category-header {
        font-family: var(--nb-font-display);
        font-size: 0.75em;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #a855f7;
        border-bottom: 1px solid #484848;
        padding-bottom: 0.4rem;
        margin-bottom: 0.5rem;
    }

    .sl-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sl-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.55rem 0;
        border-bottom: 1px solid #353535;
        font-size: 0.875em;
        color: #c0c0c0;
    }

    .sl-item:last-child {
        border-bottom: none;
    }

    .sl-checkbox {
        width: 1rem;
        height: 1rem;
        accent-color: #a855f7;
        flex-shrink: 0;
        cursor: pointer;
    }

    .sl-item.checked .sl-label {
        text-decoration: line-through;
        color: #555;
    }

    .food-empty {
        color: #c0c0c0;
        font-size: 0.875em;
        padding: 2rem 0;
    }
</style>

<div class="food-wrapper py-4">


    <h1 class="food-page-title">Shopping <span>List</span></h1>

    @if (!Model.Any())
    {
        <p class="food-empty">Your shopping list is empty.</p>
    }
    else
    {
        @foreach (var group in grouped)
        {
            <div class="sl-category">
                <div class="sl-category-header">@group.Key</div>
                <ul class="sl-list">
                    @foreach (var ingredient in group)
                    {
                        <li class="sl-item" id="sl-item-@ingredient.Id">
                            <input class="sl-checkbox" type="checkbox" id="chk-@ingredient.Id"
                                   onchange="toggleItem(@ingredient.Id, this)" />
                            <label class="sl-label" for="chk-@ingredient.Id">@ingredient.Name</label>
                        </li>
                    }
                </ul>
            </div>
        }
    }

</div>

@section Scripts {
    <script>
        function toggleItem(id, checkbox) {
            const item = document.getElementById('sl-item-' + id);
            item.classList.toggle('checked', checkbox.checked);
        }
    </script>
}
