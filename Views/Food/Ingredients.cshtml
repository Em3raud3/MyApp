@model IEnumerable<MyApp.Models.Ingredient>
@{
    ViewData["Title"] = "Ingredients";
    var grouped = Model.GroupBy(i => i.Category ?? "Uncategorized").OrderBy(g => g.Key);
}

<style>
    .food-wrapper {
        padding-left: 4rem;
        padding-right: 4rem;
    }

    @@media (max-width: 1200px) {
        .food-wrapper {
            padding-left: 2rem;
            padding-right: 2rem;
        }
    }

    @@media (max-width: 768px) {
        .food-wrapper {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }

    .food-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
    }

    .food-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: var(--nb-surface-high);
        color: var(--nb-on-surface);
        border: 1px solid var(--nb-outline);
        font-size: 0.71em;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.3rem 0.75rem;
    }

    .food-badge svg {
        color: #a855f7;
    }

    .food-page-title {
        font-family: var(--nb-font-display);
        font-size: 2em;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--nb-on-surface);
        margin: 0.5rem 0 1.5rem;
        line-height: 1.2;
    }

    .food-page-title span {
        color: #a855f7;
    }

    .ing-category {
        margin-bottom: 1.5rem;
    }

    .ing-category-header {
        font-family: var(--nb-font-display);
        font-size: 0.75em;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #a855f7;
        border-bottom: 1px solid #484848;
        padding-bottom: 0.4rem;
        margin-bottom: 0.75rem;
    }

    .ing-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .ing-pill {
        font-size: 0.8em;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--nb-on-surface);
        background-color: #272727;
        border: 1px solid #484848;
        padding: 0.3rem 0.8rem;
    }

    .food-empty {
        color: #c0c0c0;
        font-size: 0.875em;
        padding: 2rem 0;
    }
</style>

<div class="food-wrapper py-4">

    <div class="food-meta">
        <span class="food-badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 1a.5.5 0 0 1 .5.5v6.793l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 8.293V1.5A.5.5 0 0 1 8 1m-5 9h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1 0-1"/>
            </svg>
            Food
        </span>
    </div>

    <h1 class="food-page-title">My <span>Ingredients</span></h1>

    @if (!Model.Any())
    {
        <p class="food-empty">No ingredients yet. Add one to get started!</p>
    }
    else
    {
        @foreach (var group in grouped)
        {
            <div class="ing-category">
                <div class="ing-category-header">@group.Key</div>
                <ul class="ing-list">
                    @foreach (var ingredient in group)
                    {
                        <li class="ing-pill">@ingredient.Name</li>
                    }
                </ul>
            </div>
        }
    }

</div>
