@model MyApp.Models.MealPlan
@{
    ViewData["Title"] = "Edit Meal Plan";
    var allRecipes = ViewBag.AllRecipes as IEnumerable<MyApp.Models.Recipe> ?? [];
    var allQuickEats = ViewBag.AllQuickEats as IEnumerable<MyApp.Models.QuickEat> ?? [];
    var allDrinks = ViewBag.AllDrinks as IEnumerable<MyApp.Models.Drink> ?? [];
}

<style>
    .food-wrapper {
        padding-left: 4rem;
        padding-right: 4rem;
    }

    @@media (max-width: 1200px) {
        .food-wrapper {
            padding-left: 2rem;
            padding-right: 2rem;
        }
    }

    @@media (max-width: 768px) {
        .food-wrapper {
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }
    }

    .food-page-title {
        font-family: var(--nb-font-display);
        font-size: 2em;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--nb-on-surface);
        margin: 0.5rem 0 1.5rem;
        line-height: 1.2;
    }

    .food-page-title span {
        color: #a855f7;
    }

    .mp-section-label {
        font-family: var(--nb-font-display);
        font-size: 0.7em;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #a855f7;
        border-bottom: 1px solid #484848;
        padding-bottom: 0.4rem;
        margin-bottom: 1rem;
    }

    .mp-form-card {
        background: #1e1e1e;
        border: 1px solid #333;
        border-top: 3px solid #a855f7;
        border-radius: 6px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 2.5rem;
    }

    .mp-form-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
        margin-bottom: 1rem;
    }

    .mp-form-group {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        flex: 1;
        min-width: 160px;
    }

    .mp-form-group label {
        font-size: 0.75em;
        font-weight: 600;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .mp-form-group input[type="text"],
    .mp-form-group select {
        background: #141414;
        border: 1px solid #444;
        border-radius: 4px;
        color: #e0e0e0;
        padding: 0.45rem 0.65rem;
        font-size: 0.875em;
        height: 2.25rem;
        box-sizing: border-box;
    }

    .mp-form-group input:focus,
    .mp-form-group select:focus {
        outline: none;
        border-color: #a855f7;
    }

    .mp-recipe-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .mp-recipe-chip {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        background: #141414;
        border: 1px solid #444;
        border-radius: 20px;
        padding: 0.3rem 0.75rem;
        font-size: 0.8em;
        color: #c0c0c0;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
        user-select: none;
    }

    .mp-recipe-chip input[type="checkbox"] {
        accent-color: #a855f7;
    }

    .mp-recipe-chip:has(input:checked) {
        border-color: #a855f7;
        color: #e0e0e0;
        background: #2a1a3a;
    }

    .mp-recipe-chip--green input[type="checkbox"] {
        accent-color: #4ade80;
    }

    .mp-recipe-chip--green:has(input:checked) {
        border-color: #166534;
        color: #4ade80;
        background: #0d2818;
    }

    .mp-recipe-chip--blue input[type="checkbox"] {
        accent-color: #60a5fa;
    }

    .mp-recipe-chip--blue:has(input:checked) {
        border-color: #1e4a7e;
        color: #60a5fa;
        background: #0d1f3a;
    }

    .mp-submit-btn {
        background: #a855f7;
        color: #fff;
        border: none;
        border-radius: 4px;
        padding: 0.5rem 1.25rem;
        font-size: 0.875em;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s;
    }

    .mp-submit-btn:hover {
        background: #9333ea;
    }

    .mp-btn-cancel {
        font-size: 0.875em;
        padding: 0.5rem 1.25rem;
        background: transparent;
        border: 1px solid #555;
        color: #888;
        border-radius: 4px;
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
    }

    .mp-btn-cancel:hover {
        border-color: #888;
        color: #ccc;
    }

    .mp-form-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        margin-top: 0.5rem;
    }

    .food-empty {
        color: #666;
        font-size: 0.875em;
        padding: 1.5rem 0;
    }

    .mp-notes-group {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        margin-top: 1rem;
        margin-bottom: 1rem;
    }

    .mp-notes-group label {
        font-size: 0.75em;
        font-weight: 600;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .mp-notes-group textarea {
        width: 100%;
        background: #141414;
        border: 1px solid #444;
        border-radius: 4px;
        color: #e0e0e0;
        padding: 0.45rem 0.65rem;
        font-size: 0.875em;
        box-sizing: border-box;
        resize: vertical;
        outline: none;
        transition: border-color 0.15s;
        font-family: var(--nb-font-body);
        line-height: 1.5;
    }

    .mp-notes-group textarea:focus {
        border-color: #a855f7;
    }
</style>

<div class="food-wrapper py-4">
    <h1 class="food-page-title">Edit <span>Plan</span></h1>

    <div class="mp-form-card">
        <form method="post" asp-action="EditMealPlan" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <div class="mp-form-row">
                <div class="mp-form-group">
                    <label for="mp-name">Plan name</label>
                    <input id="mp-name" type="text" name="name" value="@Model.Name" required />
                </div>
                <div class="mp-form-group">
                    <label for="mp-week">Week of</label>
                    <select id="mp-week" name="weekOf" required>
                        <option value="" disabled>— pick a week —</option>
                    </select>
                </div>
            </div>

            <div class="mp-section-label" style="margin-top:0.25rem;">Pick recipes</div>
            @if (!allRecipes.Any())
            {
                <p class="food-empty">No recipes yet — add some first.</p>
            }
            else
            {
                <div class="mp-recipe-grid">
                    @foreach (var recipe in allRecipes)
                    {
                        <label class="mp-recipe-chip mp-recipe-chip--green">
                            <input type="checkbox" name="selectedRecipes" value="@recipe.Id"
                                   @(Model.Recipes.Any(r => r.Id == recipe.Id) ? "checked" : "") />
                            @recipe.Name
                        </label>
                    }
                </div>
            }

            @if (allQuickEats.Any())
            {
                <div class="mp-section-label" style="margin-top:1rem;">Pick quick eats</div>
                <div class="mp-recipe-grid">
                    @foreach (var quickEat in allQuickEats)
                    {
                        <label class="mp-recipe-chip">
                            <input type="checkbox" name="selectedQuickEats" value="@quickEat.Id"
                                   @(Model.QuickEats.Any(q => q.Id == quickEat.Id) ? "checked" : "") />
                            @quickEat.Name
                        </label>
                    }
                </div>
            }

            @if (allDrinks.Any())
            {
                <div class="mp-section-label" style="margin-top:1rem;">Pick drinks</div>
                <div class="mp-recipe-grid">
                    @foreach (var drink in allDrinks)
                    {
                        <label class="mp-recipe-chip mp-recipe-chip--blue">
                            <input type="checkbox" name="selectedDrinks" value="@drink.Id"
                                   @(Model.Drinks.Any(d => d.Id == drink.Id) ? "checked" : "") />
                            @drink.Name
                        </label>
                    }
                </div>
            }

            <div class="mp-section-label" style="margin-top:1rem;">Notes</div>
            <div class="mp-notes-group">
                <textarea name="notes" rows="3" placeholder="e.g. Check if we need olive oil, grab extra pasta...">@Model.Notes</textarea>
            </div>

            <div class="mp-form-actions">
                <button type="submit" class="mp-submit-btn">Save Changes</button>
                <a asp-action="MealPlan" class="mp-btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const select = document.getElementById('mp-week');
            const currentWeekOf = '@Model.WeekOf.ToString("yyyy-MM-dd")';

            function getMondayOf(date) {
                const d = new Date(date);
                const day = d.getDay();
                const diff = (day === 0) ? -6 : 1 - day;
                d.setDate(d.getDate() + diff);
                d.setHours(0, 0, 0, 0);
                return d;
            }

            function toISODate(d) {
                const y = d.getFullYear();
                const m = String(d.getMonth() + 1).padStart(2, '0');
                const dd = String(d.getDate()).padStart(2, '0');
                return `${y}-${m}-${dd}`;
            }

            function formatLabel(d) {
                return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
            }

            // Build a set of weeks: 4 before + current + 7 ahead, anchored to today
            const baseMonday = getMondayOf(new Date());
            const weeks = [];
            for (let i = -4; i < 8; i++) {
                const monday = new Date(baseMonday);
                monday.setDate(baseMonday.getDate() + i * 7);
                weeks.push(monday);
            }

            // Also ensure the plan's own week is in the list
            const planMonday = getMondayOf(new Date(currentWeekOf + 'T00:00:00'));
            const planKey = toISODate(planMonday);
            if (!weeks.some(w => toISODate(w) === planKey)) {
                weeks.push(planMonday);
                weeks.sort((a, b) => a - b);
            }

            weeks.forEach(monday => {
                const val = toISODate(monday);
                const opt = document.createElement('option');
                opt.value = val;
                opt.textContent = `Week of ${formatLabel(monday)}`;
                if (val === toISODate(getMondayOf(new Date()))) opt.textContent += ' (this week)';
                if (val === planKey) opt.selected = true;
                select.appendChild(opt);
            });
        })();
    </script>
}
