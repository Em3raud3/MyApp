@{
    ViewData["Title"] = "Home";
}

<div class="py-4">
    <div class="mb-4">
        <h2 class="fw-semibold text-dark mb-1">MyApp Reference Library</h2>
        <p class="text-secondary">
            A personal reference for reusable HTML and UI elements — use these pages to copy consistent
            styles, layouts, and components across projects.
        </p>
    </div>

    <hr class="mb-4" />

    <p class="section-heading text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 0.08em; color: #5a6e82;">Pages</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Basic Format</h5>
                    <p class="card-text text-secondary small">
                        A base formatting reference page for consistent typography, spacing,
                        and structural conventions used across layouts.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="BasicFormat" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Basic Page</h5>
                    <p class="card-text text-secondary small">
                        A resource list layout using Bootstrap list-groups with hover effects,
                        stretched links, and a contact block.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="BasicPage" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Basic Page Simple</h5>
                    <p class="card-text text-secondary small">
                        A simplified basic page layout for lightweight content and quick reference formatting.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="BasicPageSimple" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Basic Page Alt</h5>
                    <p class="card-text text-secondary small">
                        A sectioned content layout with a reminder panel, numbered application steps,
                        and a clickable forms list-group.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="BasicPageAlt" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Basic Page List</h5>
                    <p class="card-text text-secondary small">
                        A numbered card list layout with circular badge indicators, bold colored
                        headings, and body text — suited for ordered tips or step-by-step content.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="BasicPageList" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Basic Page Pretty</h5>
                    <p class="card-text text-secondary small">
                        An enhanced page layout with polished styling, structured sections,
                        and refined visual presentation for production-ready content.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="BasicPagePretty" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Region Page</h5>
                    <p class="card-text text-secondary small">
                        A regional coordinator contact card layout with an icon-led contact block
                        and a side-by-side map image — suited for highway safety region pages.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="RegionPage" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">WV Law Page</h5>
                    <p class="card-text text-secondary small">
                        A formal statute layout with a citation header, justified legal body text,
                        and a legislative breadcrumb footer — suited for WV code references.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="WVLawPage" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">News Page</h5>
                    <p class="card-text text-secondary small">
                        A press release layout with a badge, lead paragraph, styled quote blocks,
                        a pricing grid, and a centered contact bar — suited for DMV news and announcements.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="NewsPage" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">License Page</h5>
                    <p class="card-text text-secondary small">
                        A special plate detail layout with an image card, two-column info table,
                        and a styled back button — suited for individual DMV special plate pages.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="LicensePage" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

    </div>

    <p class="section-heading text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 0.08em; color: #5a6e82;">Tables</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Table</h5>
                    <p class="card-text text-secondary small">
                        A styled data table with a dark header, striped rows, row hover highlight,
                        left-border accent on the first column, and monospace formatting on data columns.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="Table" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Table (No Highlight)</h5>
                    <p class="card-text text-secondary small">
                        The same styled table layout without the first-column hover accent —
                        suited for non-clickable data rows.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="TableNoHighlight" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Table Accordion</h5>
                    <p class="card-text text-secondary small">
                        A collapsible accordion layout with expandable sections and nested inner sections,
                        suited for structured content with multiple levels of detail.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="TableAccordion" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Table Filters</h5>
                    <p class="card-text text-secondary small">
                        A filterable data table with text and dropdown filter inputs, live result
                        count, and a clear filters button — suited for searchable reference data.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="TableFilters" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Quick Navigation</h5>
                    <p class="card-text text-secondary small">
                        A quick navigation layout with anchor-linked section jumps and a sticky
                        nav bar — suited for long pages with multiple distinct content sections.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="QuickNavigation" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

    </div>

    <p class="section-heading text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 0.08em; color: #5a6e82;">Work in Progress</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">WIP</h5>
                    <p class="card-text text-secondary small">
                        A placeholder for whatever page I am currently working on that works as a sandbox to text changes.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="WIP" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

    </div>
</div>