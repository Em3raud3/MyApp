@{
    ViewData["Title"] = "Home";
}

<div class="py-4">
    <div class="mb-4">
        <h2 class="fw-semibold text-dark mb-1">MyApp Reference Library</h2>
        <p class="text-secondary">
            A personal reference for reusable HTML and UI elements — use these pages to copy consistent
            styles, layouts, and components across projects.
        </p>
    </div>

    <hr class="mb-4" />

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Basic Page</h5>
                    <p class="card-text text-secondary small">
                        A resource list layout using Bootstrap list-groups with hover effects,
                        stretched links, and a contact block.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="BasicPage" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Table</h5>
                    <p class="card-text text-secondary small">
                        A styled data table with a dark header, striped rows, row hover highlight,
                        left-border accent on the first column, and monospace formatting on data columns.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="Table" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0" style="background-color: #edf1f7;">
                <div class="card-body px-4 py-3">
                    <h5 class="card-title fw-semibold text-dark mb-1">Table (No Highlight)</h5>
                    <p class="card-text text-secondary small">
                        The same styled table layout without the first-column hover accent —
                        suited for non-clickable data rows.
                    </p>
                </div>
                <div class="card-footer border-0 px-4 pb-3" style="background-color: #edf1f7;">
                    <a asp-controller="Home" asp-action="TableNoHighlight" class="btn btn-sm btn-outline-secondary">View Page</a>
                </div>
            </div>
        </div>

    </div>
</div>