<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filterTitle    = document.getElementById('filterTitle');
        const filterNumber   = document.getElementById('filterNumber');
        const filterCategory = document.getElementById('filterCategory');
        const clearBtn       = document.getElementById('clearFilters');
        const noResultsRow   = document.getElementById('noResultsRow');
        const resultsCount   = document.getElementById('resultsCount');
        const rows           = Array.from(document.querySelectorAll('#formsTableBody tr:not(#noResultsRow)'));
        const totalRows      = rows.length;

        function applyFilters() {
            const title    = filterTitle.value.trim().toLowerCase();
            const number   = filterNumber.value.trim().toLowerCase();
            const category = filterCategory.value;

            let visibleCount = 0;

            rows.forEach(row => {
                const cells       = row.querySelectorAll('td');
                const rowTitle    = cells[0].textContent.trim().toLowerCase();
                const rowNumber   = cells[2].textContent.trim().toLowerCase();
                const rowCategory = cells[3].textContent.trim();

                const matchesTitle    = !title    || rowTitle.includes(title);
                const matchesNumber   = !number   || rowNumber.includes(number);
                const matchesCategory = !category || rowCategory === category;

                const visible = matchesTitle && matchesNumber && matchesCategory;
                row.style.display = visible ? '' : 'none';
                if (visible) visibleCount++;
            });

            noResultsRow.style.display = visibleCount === 0 ? '' : 'none';
            resultsCount.textContent = `Showing ${visibleCount} of ${totalRows} result${totalRows !== 1 ? 's' : ''}`;
        }

        function clearFilters() {
            filterTitle.value    = '';
            filterNumber.value   = '';
            filterCategory.value = '';
            applyFilters();
        }

        filterTitle.addEventListener('input', applyFilters);
        filterNumber.addEventListener('input', applyFilters);
        filterCategory.addEventListener('change', applyFilters);
        clearBtn.addEventListener('click', clearFilters);

        applyFilters();
    });
</script>